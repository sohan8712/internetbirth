# internetbirth — API Configuration
# Add your API keys below and rename this file to .env.local
# The application works without any API keys using free, keyless APIs
# Keys auto-enable richer data when present

# TMDb — Movie posters, descriptions, IMDb links
# https://www.themoviedb.org/settings/api
NEXT_PUBLIC_TMDB_API_KEY=

# RAWG — Game covers, platforms, developers
# https://rawg.io/apidocs
NEXT_PUBLIC_RAWG_API_KEY=

# YouTube Data API v3 — Music video links
# https://console.cloud.google.com/apis/library/youtube.googleapis.com
NEXT_PUBLIC_YOUTUBE_API_KEY=

# Last.fm — Artist images, album art fallback
# https://www.last.fm/api
NEXT_PUBLIC_LASTFM_API_KEY=
